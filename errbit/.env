# ============================================================
# Errbit Configuration
# ============================================================

# --- Core ---
ERRBIT_HOST=errbit.localhost.dev
ERRBIT_PORT=8080
ERRBIT_LOG_LOCATION=STDOUT

# Set to "true" on first run to create MongoDB indexes and admin user,
# then set to "false" for subsequent starts.
ERRBIT_BOOTSTRAP=true

# Generate your own: openssl rand -hex 64
SECRET_KEY_BASE=CHANGEME_generate_with_openssl_rand_hex_64

# --- Admin user (only used during bootstrap) ---
ERRBIT_ADMIN_EMAIL=admin@errbit.example.com
ERRBIT_ADMIN_PASSWORD=password

# --- Email notifications ---
ERRBIT_EMAIL_FROM=errbit@example.com
ERRBIT_EMAIL_AT_NOTICES=[1,10,100]
ERRBIT_PER_APP_EMAIL_AT_NOTICES=false
ERRBIT_NOTIFY_AT_NOTICES=[0]
ERRBIT_PER_APP_NOTIFY_AT_NOTICES=false

# --- UI ---
CONFIRM_RESOLVE_ERR=true
ERRBIT_CONFIRM_ERR_ACTIONS=true
ERRBIT_USER_HAS_USERNAME=false
ERRBIT_USE_GRAVATAR=true
ERRBIT_GRAVATAR_DEFAULT=identicon
ALLOW_COMMENTS_WITH_ISSUE_TRACKER=true

# --- GitHub OAuth (optional) ---
GITHUB_AUTHENTICATION=false
GITHUB_URL=https://github.com
GITHUB_API_URL=https://api.github.com
GITHUB_ACCESS_SCOPE=[repo]
# GITHUB_CLIENT_ID=
# GITHUB_SECRET=

# --- Google OAuth (optional) ---
GOOGLE_AUTHENTICATION=false
# GOOGLE_CLIENT_ID=
# GOOGLE_SECRET=
